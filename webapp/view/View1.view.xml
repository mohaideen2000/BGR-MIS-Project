<mvc:View controllerName="projectmisreport.controller.View1"
xmlns:mvc="sap.ui.core.mvc"
xmlns="sap.m"
xmlns:table="sap.ui.table"
xmlns:core="sap.ui.core">

  <VBox class="sapUiSmallMargin">
   <VBox class="headerContainer">
    <Title text="{/header}" level="H2" class="headerTitle"/>
    <Title text="{/header1}" level="H1" class="headerTitle1"/>
   </VBox>
<!-- KPI SECTION HEADER -->
    <Text
        text="KEY PERFORMANCE INDICATORS"
        class="kpiSectionHeader"/>

    <!-- KPI TILES -->
        <FlexBox
        items="{/kpi}"
        wrap="Wrap"
        justifyContent="SpaceBetween"
        alignItems="Stretch"
        class="sapUiMediumMarginTop">

        <items>
            <VBox 
                class="kpiBox {color}" 
                alignItems="Center" 
                justifyContent="Center"
                width="100%">

                <Text text="{title}" class="kpiTitle"/>

                <Text text="{value}" class="kpiNumber"/>

                <Text text="{desc}" class="kpiDesc"/>

            </VBox>
        </items>

    </FlexBox>
      <VBox class="sapUiMediumMarginTop">

    <!-- Table Title -->
    <Text
        text="PRODUCTION ORDER STATUS SUMMARY"
        width="100%"
        textAlign="Center"
        class="tableHeader"/>

    <table:Table
        id="idTable"
        rows="{/orders}"
        visibleRowCount="8"
        class="sapUiSmallMarginTop">
        <table:columns>

            <table:Column>
                <Label text="WBS Element"/>
                <table:template>
                    <Text text="{wbs}"/>
                </table:template>
            </table:Column>

            <table:Column>
                <Label text="Description"/>
                <table:template>
                    <Text text="{desc}"/>
                </table:template>
            </table:Column>

            <table:Column>
                <Label text="Order No"/>
                <table:template>
                    <Text text="{orderNo}"/>
                </table:template>
            </table:Column>

            <table:Column>
                <Label text="Quantity"/>
                <table:template>
                    <Text text="{qty}"/>
                </table:template>
            </table:Column>
           <table:Column>
                <Label text="Header"/>
                <table:template>
                    <Text text="{header}"/>
                </table:template>
            </table:Column>

            <table:Column>
                <Label text="Status"/>
                <table:template>
                    <ObjectStatus text="{status}"/>
                </table:template>
            </table:Column>

            <table:Column>
                <Label text="Completion %"/>
                <table:template>
                    <ProgressIndicator
                        percentValue="{percent}"
                        displayValue="{percent}%"/>
                </table:template>
            </table:Column>

        </table:columns>

    </table:Table>
</VBox>
  </VBox>
</mvc:View>